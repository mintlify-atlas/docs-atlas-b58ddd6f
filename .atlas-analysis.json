{
  "projectType": "api-service",
  "projectName": "Smart Enviro Backend",
  "projectDescription": "A Laravel-based REST API backend for managing IoT environmental monitoring devices, receiving and storing sensor telemetry from ESP32 hardware, and providing real-time actuator control.",
  "theme": "luma",
