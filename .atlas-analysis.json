  "keyFeatures": [
    "Laravel Sanctum token-based authentication with single-session enforcement",
    "ESP32 device sync endpoint for bidirectional command and configuration delivery",
    "Sensor telemetry ingestion with device token authentication",
    "Actuator state control (ON/OFF/STANDBY) via mobile app API",
    "Device property management for configurable thresholds and automation settings",
    "Historical sensor data aggregation by hour, day, or month for charting",
    "Device discovery and user-claiming workflow",
    "Docker-based deployment with MySQL and Redis via Laravel Sail"
  ],
  "publicApiSurface": [
    "POST /api/login",
    "POST /api/register",
    "DELETE /api/logout",
    "GET /api/user",
    "GET /api/device/sync",
    "GET /api/my-devices",
    "GET /api/my-devices/{id}",
    "POST /api/my-devices/{id}/toggle",
    "PUT /api/my-devices/{id}/properties",
    "GET /api/devices/available",
    "POST /api/devices/{id}/add",
    "POST /api/sensor-data",
    "GET /api/sensor-data",
    "GET /api/sensor-data/{id}",
    "DELETE /api/sensor-data/{id}",
    "GET /api/sensor-data/history"
  ]
